# ──────────────────────────────────────────
#  RelicSync — Root .gitignore
# ──────────────────────────────────────────

# Environment variables (NEVER commit these)
.env
.env.*
!.env.example

# ── Java / Backend ──
*.class
*.jar
!backend/lib/*.jar
bin/
out/
target/
*.war
*.ear

# ── Node / Frontend ──
node_modules/
.next/
/out/
/build
.pnp
.pnp.*

# ── Logs ──
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# ── OS Files ──
.DS_Store
Thumbs.db
desktop.ini

# ── IDE Files ──
.vscode/
.idea/
*.iml
*.ipr
*.iws

# ── TypeScript ──
*.tsbuildinfo
next-env.d.ts

# ── Firebase / GCP ──
.firebase/
firebase-debug.log
firestore-debug.log
.genkit/

# ── Testing ──
coverage/

# ── Misc ──
*.pem
.vercel
